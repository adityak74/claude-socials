{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/adityak74/claude-socials/main/marketplace.schema.json",
  "title": "claude-socials Marketplace",
  "description": "Schema for the claude-socials skill marketplace registry",
  "type": "object",
  "required": ["name", "version", "skills"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "repository": { "type": "string", "format": "uri" },
    "homepage": { "type": "string", "format": "uri" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "platform", "path", "skill_file"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "platform": { "type": "string" },
          "path": { "type": "string" },
          "skill_file": { "type": "string" },
          "raw_url": { "type": "string", "format": "uri" },
          "triggers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "prerequisites": {
            "type": "object",
            "properties": {
              "mcp": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "package"],
                  "properties": {
                    "name": { "type": "string" },
                    "package": { "type": "string" },
                    "install": { "type": "string" },
                    "config": { "type": "object" },
                    "docs": { "type": "string", "format": "uri" }
                  }
                }
              }
            }
          },
          "env": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["key", "description", "required"],
              "properties": {
                "key": { "type": "string" },
                "description": { "type": "string" },
                "required": { "type": "boolean" },
                "secret": { "type": "boolean" }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "global": { "type": "string" },
              "project": { "type": "string" },
              "manual": { "type": "object" }
            }
          }
        }
      }
    }
  }
}
